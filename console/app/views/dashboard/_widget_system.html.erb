<% upd = update_widget(agent) %>
<article class="widget tui-box">
  <h3>system</h3>
  <div class="kv-list">
    <div><span>os</span><strong title="<%= metric_value(agent, "generic_sys_os") %>"><%= metric_value(agent, "generic_sys_os") %></strong></div>
    <div><span>kernel</span><strong title="<%= metric_value(agent, "generic_sys_kernel") %>"><%= metric_value(agent, "generic_sys_kernel") %></strong></div>
    <div><span>agent</span><strong><%= metric_value(agent, "generic_agent_version", metric_value(agent, "generic_lumenmon_version", "-")) %></strong></div>
    <% if upd %>
      <div><span>updates</span><strong class="<%= "warn-text" if upd[:status] == "warning" %><%= "crit-text" if upd[:status] == "critical" %>"><%= upd[:total] %>/<%= upd[:security] %>s</strong></div>
    <% end %>
    <div><span>hb</span><strong><%= metric_value(agent, "generic_heartbeat") %></strong></div>
  </div>
</article>
