<% value = metric_number(agent, "generic_cpu") %>
<% tone = metric_tone(agent, "generic_cpu") %>
<% bar_class = tone == "warn-text" ? "warn" : (%w[crit-text stale-text].include?(tone) ? "crit" : "") %>
<article class="widget tui-box">
  <h3>cpu</h3>
  <div class="tui-metric-value <%= tone %>">
    <%= value ? format("%.1f", value) : "-" %><span class="tui-unit">%</span>
  </div>
  <% if value %>
    <div class="tui-metric-bar <%= bar_class %>"><span style="width: <%= [value, 100].min %>%"></span></div>
  <% end %>
</article>
