<% value = metric_number(agent, "generic_disk") %>
<article class="widget tui-box">
  <h3>disk</h3>
  <div class="tui-metric-value <%= metric_tone(agent, "generic_disk") %>">
    <%= value ? format("%.1f", value) : "-" %><span class="tui-unit">%</span>
  </div>
  <% sample = metric_sample(agent, "generic_disk") %>
  <% if sample && (sample.warn_max || sample.max) %>
    <div class="tui-metric-bounds">warn <%= sample.warn_max || "-" %> · max <%= sample.max || "-" %></div>
  <% end %>
</article>
