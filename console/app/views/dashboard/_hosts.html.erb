<% if agents.any? %>
  <table class="agents-table">
    <thead>
      <tr>
        <td>hostname</td>
        <td>cpu</td>
        <td>mem</td>
        <td>disk</td>
      </tr>
    </thead>
    <tbody>
      <% agents.each do |agent| %>
        <tr class="agent-row" id="agent-row-<%= agent[:id] %>" data-agent-target="<%= agent[:id] %>">
          <td>
            <div class="agent-name">
              <span class="status-dot <%= agent[:status] %>"></span>
              <strong><%= agent[:hostname] %></strong>
              <button class="host-edit-button"
                      type="button"
                      title="edit display name"
                      aria-label="Edit display name for <%= agent[:hostname] %>"
                      data-agent-edit="<%= agent[:id] %>"
                      data-agent-name="<%= agent[:hostname] %>">✎</button>
              <% if agent[:unread_mail].to_i > 0 %>
                <span class="mail-indicator" title="<%= agent[:unread_mail] %> unread">
                  <svg width="13" height="10" viewBox="0 0 16 12" aria-hidden="true">
                    <rect x="0.5" y="0.5" width="15" height="11" rx="1" fill="none" stroke="currentColor"></rect>
                    <path d="M1 1l7 6 7-6" fill="none" stroke="currentColor"></path>
                  </svg>
                </span>
              <% end %>
            </div>
          </td>
          <td><%= metric_percent(agent, "generic_cpu") %></td>
          <td><%= metric_percent(agent, "generic_memory") %></td>
          <td><%= metric_percent(agent, "generic_disk") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty-state">waiting for first agent</div>
<% end %>
