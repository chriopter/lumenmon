#!/bin/bash
# Starts a full local dev stack with live console and three containerized agents.
# Resets local data first, then keeps the console process in the foreground.
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DATA_ROOT="${LUMENMON_DEV_DATA_DIR:-$APP_ROOT/dev/data/local-console}"
MQTT_PORT="${MQTT_PORT:-8884}"
DEV_PID=""

require_command() {
    local cmd="$1"

    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Missing required command: $cmd" >&2
        exit 1
    fi
}

wait_for_file() {
    local path="$1" label="$2" attempts="${3:-60}"

    while [ "$attempts" -gt 0 ]; do
        [ -f "$path" ] && return 0
        if [ -n "$DEV_PID" ] && ! kill -0 "$DEV_PID" 2>/dev/null; then
            echo "bin/dev exited before $label was ready" >&2
            wait "$DEV_PID" 2>/dev/null || true
            exit 1
        fi
        attempts=$((attempts - 1))
        sleep 1
    done

    echo "Timed out waiting for $label" >&2
    return 1
}

wait_for_port() {
    local host="$1" port="$2" label="$3" attempts="${4:-60}"

    while [ "$attempts" -gt 0 ]; do
        if (echo > "/dev/tcp/$host/$port") >/dev/null 2>&1; then
            return 0
        fi
        if [ -n "$DEV_PID" ] && ! kill -0 "$DEV_PID" 2>/dev/null; then
            echo "bin/dev exited before $label was ready" >&2
            wait "$DEV_PID" 2>/dev/null || true
            exit 1
        fi
        attempts=$((attempts - 1))
        sleep 1
    done

    echo "Timed out waiting for $label" >&2
    return 1
}

cleanup() {
    if [ -n "$DEV_PID" ]; then
        kill "$DEV_PID" 2>/dev/null || true
        wait "$DEV_PID" 2>/dev/null || true
    fi
}

cd "$APP_ROOT"

require_command docker
if ! docker info >/dev/null 2>&1; then
    echo "Docker daemon is not reachable; check that Docker is running and your user can access it" >&2
    exit 1
fi

trap cleanup EXIT INT TERM

./bin/dev --reset &
DEV_PID="$!"

wait_for_file "$DATA_ROOT/mqtt/fingerprint" "local MQTT certificate"
wait_for_port "127.0.0.1" "$MQTT_PORT" "local MQTT TLS listener"

./dev/add3

echo ""
echo "Full dev stack is running. Stop with Ctrl-C."
wait "$DEV_PID"
