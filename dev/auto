#!/bin/bash
# Starts a full local dev stack with live console and three agents.
# Resets local data first, then keeps the console process in the foreground.
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONSOLE_ROOT="$APP_ROOT/console"
DATA_ROOT="${LUMENMON_DEV_DATA_DIR:-$APP_ROOT/dev/data/local-console}"
MQTT_PORT="${MQTT_PORT:-8884}"
CONSOLE_HOST="${CONSOLE_HOST:-localhost}"
LUMENMON_WEB_PORT="${LUMENMON_WEB_PORT:-8080}"
DEV_PID=""
VIRTUAL_PID=""

export LUMENMON_WEB_PORT

require_command() {
    local cmd="$1"

    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Missing required command: $cmd" >&2
        exit 1
    fi
}

preflight() {
    require_command bundle
    require_command docker
    require_command gem
    require_command mosquitto
    require_command mosquitto_passwd
    require_command npm
    require_command openssl

    if ! docker info >/dev/null 2>&1; then
        echo "Docker daemon is not reachable; check that Docker is running and your user can access it" >&2
        exit 1
    fi
}

wait_for_file() {
    local path="$1" label="$2" attempts="${3:-60}"

    while [ "$attempts" -gt 0 ]; do
        [ -f "$path" ] && return 0
        if [ -n "$DEV_PID" ] && ! kill -0 "$DEV_PID" 2>/dev/null; then
            echo "dev/console exited before $label was ready" >&2
            wait "$DEV_PID" 2>/dev/null || true
            exit 1
        fi
        attempts=$((attempts - 1))
        sleep 1
    done

    echo "Timed out waiting for $label" >&2
    return 1
}

wait_for_port() {
    local host="$1" port="$2" label="$3" attempts="${4:-60}"

    while [ "$attempts" -gt 0 ]; do
        if (echo > "/dev/tcp/$host/$port") >/dev/null 2>&1; then
            return 0
        fi
        if [ -n "$DEV_PID" ] && ! kill -0 "$DEV_PID" 2>/dev/null; then
            echo "dev/console exited before $label was ready" >&2
            wait "$DEV_PID" 2>/dev/null || true
            exit 1
        fi
        attempts=$((attempts - 1))
        sleep 1
    done

    echo "Timed out waiting for $label" >&2
    return 1
}

cleanup() {
    if [ -n "$VIRTUAL_PID" ]; then
        kill "$VIRTUAL_PID" 2>/dev/null || true
        wait "$VIRTUAL_PID" 2>/dev/null || true
    fi

    if [ -n "$DEV_PID" ]; then
        kill "$DEV_PID" 2>/dev/null || true
        wait "$DEV_PID" 2>/dev/null || true
    fi

    docker stop \
        lumenmon-dev-agent-1 \
        lumenmon-dev-agent-2 \
        lumenmon-dev-agent-3 \
        2>/dev/null || true
}

create_invite() {
    if [ ! -f "$DATA_ROOT/mqtt/fingerprint" ]; then
        echo "Console is missing MQTT certificate data" >&2
        return 1
    fi

    if ! (echo > "/dev/tcp/127.0.0.1/$MQTT_PORT") >/dev/null 2>&1; then
        echo "Local MQTT listener is not reachable" >&2
        return 1
    fi

    (
        cd "$CONSOLE_ROOT"
        CONSOLE_HOST="$CONSOLE_HOST" \
        LUMENMON_DATA_DIR="$DATA_ROOT" \
        MQTT_PORT="$MQTT_PORT" \
            core/enrollment/invite_create.sh
    ) 2>&1 | grep "^lumenmon://" | head -1 || true
}

start_agents() {
    local i agent_name agent_data invite

    echo "Building dev agent image..."
    docker build -t lumenmon-dev-agent -f dev/Dockerfile.agent .

    echo "Cleaning up existing test agents..."
    for i in 1 2 3; do
        docker stop "lumenmon-dev-agent-$i" 2>/dev/null || true
        docker rm "lumenmon-dev-agent-$i" 2>/dev/null || true
    done
    rm -rf dev/data/agents 2>/dev/null || true

    for i in 1 2 3; do
        agent_name="agent-$i"
        agent_data="dev/data/agents/$agent_name"

        echo "Creating $agent_name..."
        mkdir -p "$agent_data/mqtt"

        invite="$(create_invite)"
        if [ -z "$invite" ]; then
            echo "Failed to create invite for $agent_name" >&2
            exit 1
        fi

        docker run --rm \
            --network host \
            -e LUMENMON_AUTO_ACCEPT=1 \
            -v "$PWD/$agent_data:/opt/lumenmon/data" \
            lumenmon-dev-agent \
            /opt/lumenmon/core/setup/register.sh "$invite" >/dev/null 2>&1

        docker run -d \
            --name "lumenmon-dev-agent-$i" \
            --network host \
            -v "$PWD/$agent_data:/opt/lumenmon/data" \
            --restart unless-stopped \
            lumenmon-dev-agent >/dev/null

        echo "  Started $agent_name"
    done
}

start_virtual_agent() {
    local agent_data="dev/data/agents/virtual"
    local invite

    rm -rf "$agent_data"
    mkdir -p "$agent_data/mqtt"

    invite="$(create_invite)"
    if [ -z "$invite" ]; then
        echo "Failed to create invite for virtual agent" >&2
        exit 1
    fi

    docker run --rm \
        --network host \
        -e LUMENMON_AUTO_ACCEPT=1 \
        -v "$PWD/$agent_data:/opt/lumenmon/data" \
        lumenmon-dev-agent \
        /opt/lumenmon/core/setup/register.sh "$invite" >/dev/null 2>&1

    virtual_agent_loop &
    VIRTUAL_PID="$!"
    echo "  Started virtual (synthetic ticker, pid $VIRTUAL_PID)"
}

virtual_agent_loop() {
    export LC_ALL=C  # keep printf/awk decimals as periods, not locale commas
    local data="dev/data/agents/virtual/mqtt"
    local log="dev/data/agents/virtual/publish.log"
    local user pass host port
    user=$(cat "$data/username")
    pass=$(cat "$data/password")
    host=$(cat "$data/host")
    port=$(cat "$data/port")

    _pub() {
        local metric="$1" value="$2" type="$3" interval="${4:-1}"
        local min="${5:-}" max="${6:-}" warn_min="${7:-}" warn_max="${8:-}"
        local jv="$value"
        [ "$type" = "TEXT" ] && jv="\"$value\""
        local payload="{\"value\":$jv,\"type\":\"$type\",\"interval\":$interval"
        [ -n "$min" ] && payload="$payload,\"min\":$min"
        [ -n "$max" ] && payload="$payload,\"max\":$max"
        [ -n "$warn_min" ] && payload="$payload,\"warn_min\":$warn_min"
        [ -n "$warn_max" ] && payload="$payload,\"warn_max\":$warn_max"
        payload="$payload}"
        mosquitto_pub -h "$host" -p "$port" -u "$user" -P "$pass" \
            --cafile "$data/server.crt" --insecure \
            -t "metrics/$user/$metric" -m "$payload" 2>>"$log" || true
    }

    _mail() {
        local count="$1" now="$2"
        local payload
        payload="{\"mail_from\":\"dev-mail@$user.local\",\"mail_to\":\"$user@localhost\",\"subject\":\"virtual mail $count\",\"body\":\"synthetic virtual mail $count at $now\"}"
        mosquitto_pub -h "$host" -p "$port" -u "$user" -P "$pass" \
            --cafile "$data/server.crt" --insecure \
            -t "metrics/$user/mail_message" -m "$payload" 2>>"$log" || true
    }

    _pub "generic_hostname"      "virtual-tick"     TEXT 60
    _pub "generic_agent_version" "v0.0-virtual"     TEXT 60
    _pub "generic_sys_os"        "synthetic linux"  TEXT 60
    _pub "generic_sys_kernel"    "0.0.0-virtual"    TEXT 60

    local boot_ts now uptime cpu mem disk tick
    boot_ts=$(date +%s)
    tick=0
    while :; do
        now=$(date +%s)
        uptime=$((now - boot_ts))
        tick=$((tick + 1))
        # Pure-bash arithmetic — locale-safe (no awk/printf decimals)
        cpu="$((RANDOM % 60 + 20)).$((RANDOM % 10))"
        mem="$((RANDOM % 40 + 30)).$((RANDOM % 10))"
        disk="$((RANDOM % 25 + 50)).$((RANDOM % 10))"

        _pub "generic_cpu"        "$cpu"     REAL    1 0 100 0 90
        _pub "generic_memory"     "$mem"     REAL    1 0 100 0 90
        _pub "generic_disk"       "$disk"    REAL    1 0 100 0 85
        _pub "generic_heartbeat"  "$now"     INTEGER 1
        _pub "generic_sys_uptime" "$uptime"  INTEGER 60

        if [ $((tick % 5)) -eq 0 ]; then
            _mail "$tick" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        fi

        sleep 1
    done
}

cd "$APP_ROOT"

preflight

trap cleanup EXIT INT TERM

./dev/console --reset &
DEV_PID="$!"

wait_for_file "$DATA_ROOT/mqtt/fingerprint" "local MQTT certificate"
wait_for_port "127.0.0.1" "$MQTT_PORT" "local MQTT TLS listener"

start_agents
start_virtual_agent

echo ""
echo "Full dev stack is running. Stop with Ctrl-C."
wait "$DEV_PID"
