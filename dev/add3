#!/bin/bash
# Spawns three dev agent containers and mail tickers.
# Uses the running local console to create invites and synthetic mail.
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONSOLE_ROOT="$APP_ROOT/console"
DATA_ROOT="${LUMENMON_DEV_DATA_DIR:-$APP_ROOT/dev/data/local-console}"
MQTT_PORT="${MQTT_PORT:-8884}"
CONSOLE_HOST="${CONSOLE_HOST:-localhost}"

cd "$APP_ROOT"

require_command() {
    local cmd="$1"

    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Missing required command: $cmd" >&2
        exit 1
    fi
}

create_invite() {
    if docker ps --format '{{.Names}}' | grep -qx lumenmon-console; then
        docker exec lumenmon-console /app/core/enrollment/invite_create.sh 2>&1 | grep "^lumenmon://" | head -1 || true
        return
    fi

    if [ ! -f "$DATA_ROOT/mqtt/fingerprint" ]; then
        echo "Console not running. Start it first with dev/console or dev/auto" >&2
        return 1
    fi

    if ! (echo > "/dev/tcp/127.0.0.1/$MQTT_PORT") >/dev/null 2>&1; then
        echo "Local MQTT listener is not reachable. Start the console first with dev/console or dev/auto" >&2
        return 1
    fi

    (
        cd "$CONSOLE_ROOT"
        CONSOLE_HOST="$CONSOLE_HOST" \
        LUMENMON_DATA_DIR="$DATA_ROOT" \
        MQTT_PORT="$MQTT_PORT" \
            core/enrollment/invite_create.sh
    ) 2>&1 | grep "^lumenmon://" | head -1 || true
}

start_mail_ticker() {
    local index="$1"
    local agent_data="$2"
    local container="lumenmon-dev-agent-$index-mail"

    docker rm -f "$container" >/dev/null 2>&1 || true
    docker run -d \
        --name "$container" \
        --network host \
        -v "$PWD/$agent_data:/opt/lumenmon/data" \
        --restart unless-stopped \
        lumenmon-dev-agent \
        /bin/bash -lc '
            set -euo pipefail
            data=/opt/lumenmon/data/mqtt
            log=/opt/lumenmon/data/mail-tick.log
            user=$(cat "$data/username")
            pass=$(cat "$data/password")
            host=$(cat "$data/host")
            port=$(cat "$data/port")
            count=0
            while :; do
                count=$((count + 1))
                now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
                payload="{\"mail_from\":\"dev-mail@$user.local\",\"mail_to\":\"$user@localhost\",\"subject\":\"agent mail $count\",\"body\":\"synthetic agent mail $count at $now\"}"
                mosquitto_pub -h "$host" -p "$port" -u "$user" -P "$pass" \
                    --cafile "$data/server.crt" --insecure \
                    -t "metrics/$user/mail_message" -m "$payload" 2>>"$log" || true
                sleep 5
            done
        ' >/dev/null
}

require_command docker

echo "Adding 3 dev agents with 5s mail tickers..."

if ! docker info >/dev/null 2>&1; then
    echo "Docker daemon is not reachable; check that Docker is running and your user can access it" >&2
    exit 1
fi

if ! docker image inspect lumenmon-dev-agent >/dev/null 2>&1; then
    echo "Building dev agent image..."
    docker build -t lumenmon-dev-agent -f dev/Dockerfile.agent .
fi

echo "Cleaning up existing test agents..."
for i in 1 2 3; do
    docker rm -f "lumenmon-dev-agent-$i" "lumenmon-dev-agent-$i-mail" >/dev/null 2>&1 || true
    rm -rf "dev/data/agents/agent-$i"
done

for i in 1 2 3; do
    agent_name="agent-$i"
    agent_data="dev/data/agents/$agent_name"

    echo "Creating $agent_name..."
    mkdir -p "$agent_data/mqtt"

    invite="$(create_invite)"
    if [ -z "$invite" ]; then
        echo "Failed to create invite for $agent_name" >&2
        exit 1
    fi

    docker run --rm \
        --network host \
        -e LUMENMON_AUTO_ACCEPT=1 \
        -v "$PWD/$agent_data:/opt/lumenmon/data" \
        lumenmon-dev-agent \
        /opt/lumenmon/core/setup/register.sh "$invite" >/dev/null 2>&1

    docker run -d \
        --name "lumenmon-dev-agent-$i" \
        --network host \
        -v "$PWD/$agent_data:/opt/lumenmon/data" \
        --restart unless-stopped \
        lumenmon-dev-agent >/dev/null

    start_mail_ticker "$i" "$agent_data"
    echo "  Started $agent_name + mail ticker"
done

echo ""
echo "All 3 agents started."
echo "Mail: one synthetic message per agent every 5 seconds"
echo "View: http://localhost:8080"
echo "Stop: docker stop lumenmon-dev-agent-{1,2,3} lumenmon-dev-agent-{1,2,3}-mail"
