#!/bin/bash
# Spawn 3 Glances agents for multi-agent testing.
# Requires console running (use ./dev/auto first).

set -e

if ! docker ps | grep -q lumenmon-console; then
    echo "❌ Console not running. Run ./dev/auto first"
    exit 1
fi

echo "🚀 Adding 3 Glances agents..."

# Clean up
for i in 1 2 3; do
    docker stop lumenmon-agent-$i 2>/dev/null || true
    docker rm lumenmon-agent-$i 2>/dev/null || true
done
rm -rf agent/data/agents 2>/dev/null
mkdir -p agent/data/agents

# Create each agent
for i in 1 2 3; do
    echo ""
    echo "📦 Agent $i/3"

    DATA_DIR="agent/data/agents/agent-$i"
    mkdir -p "$DATA_DIR/mqtt" "$DATA_DIR/glances"

    # Get invite
    INVITE=$(docker exec lumenmon-console /app/core/enrollment/invite_create.sh 2>&1 | grep "lumenmon register" | sed 's/.*lumenmon register "\(.*\)"/\1/')

    # Parse
    STRIPPED="${INVITE#lumenmon://}"
    CONN_STRING="${STRIPPED%#*}"

    if [[ "$CONN_STRING" =~ ^([^:]+):([^@]+)@([^:]+):([0-9]+)$ ]]; then
        USERNAME="${BASH_REMATCH[1]}"
        PASSWORD="${BASH_REMATCH[2]}"
        HOST="${BASH_REMATCH[3]}"
    else
        echo "  ❌ Failed"
        continue
    fi

    # Save config
    echo "$USERNAME" > "$DATA_DIR/mqtt/username"
    echo "$PASSWORD" > "$DATA_DIR/mqtt/password"
    docker exec lumenmon-console cat /data/mqtt/server.crt > "$DATA_DIR/mqtt/server.crt"

    cat > "$DATA_DIR/glances/glances.conf" <<EOF
[global]
check_update=false
refresh=3

[mqtt]
host=$HOST
port=1884
user=$USERNAME
password=$PASSWORD
topic=metrics/$USERNAME
topic_structure=per-metric
tls=false
callback_api_version=2
EOF

    # Start
    docker run -d \
        --name "lumenmon-agent-$i" \
        --hostname "agent-$i" \
        --network lumenmon-net \
        -v "$(pwd)/$DATA_DIR:/data:ro" \
        nicolargo/glances:4.2.0-full \
        glances --quiet --export mqtt --conf /data/glances/glances.conf \
        > /dev/null

    echo "  ✅ $USERNAME"
done

echo ""
echo "⏳ Waiting for metrics..."
sleep 10

AGENT_COUNT=$(docker ps --filter name=lumenmon-agent- | grep -v CONTAINER | wc -l)
echo ""
echo "✅ Done! $AGENT_COUNT agents running"
echo "📊 http://localhost:8080"
