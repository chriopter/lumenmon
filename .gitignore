# Local environment
.env
.env*.local
.reset
.codex
.codex/

# Ruby / Rails
*.rbc
.bundle/
vendor/bundle/
console/.bundle/
console/vendor/bundle/
console/config/master.key
console/config/credentials.yml.enc
console/config/credentials/*.key
console/log/*
!console/log/.keep
console/tmp/*
!console/tmp/.keep
!console/tmp/pids/
console/tmp/pids/*
!console/tmp/pids/.keep
console/storage/*
!console/storage/.keep
console/public/assets/
console/app/assets/builds/*
!console/app/assets/builds/.keep

# Node
node_modules/
console/node_modules/
dev/tests/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log
.yarn-integrity

# Lumenmon runtime data
console/data/**
!console/data/**/.gitkeep
console-legacy/data/**
!console-legacy/data/**/.gitkeep
agent/data/**
!agent/data/**/.gitkeep
dev/data/
docker-compose.override.yml

# Python / misc
__pycache__/
*.pyc
*.orig

# Playwright artifacts
dev/tests/test-results/
dev/tests/playwright-report/
dev/tests/playwright/.cache/
